# ============ 应用安全 ============
SECRET_KEY=change-me-in-production-please
# JWT 过期时间（秒）
ACCESS_TOKEN_EXPIRE_SECONDS=86400

# ============ 数据库 ============
# 本地直连 (开发 / 本机调试)
DATABASE_URL=postgresql+asyncpg://ann:ann@localhost:5432/ann
# 容器内 (docker compose) 时使用 postgres 主机名
# DATABASE_URL=postgresql+asyncpg://ann:ann@postgres:5432/ann

# ============ 缓存 / 任务队列 ============
REDIS_URL=redis://localhost:6379/0

# ============ 大模型 (RAG) ============
# LLM_PROVIDER 可选：mock / dashscope / openai / anthropic
LLM_PROVIDER=mock
LLM_MODEL=qwen-plus               # anthropic 时建议 claude-opus-4-20250514
LLM_API_KEY=                       # 通用（dashscope/openai/anthropic 共用）
ANTHROPIC_API_KEY=                 # 可选，覆盖 LLM_API_KEY 仅用于 anthropic
LLM_BASE_URL=                      # 仅 openai 兼容 endpoint 时使用

# ============ 跨域 / 前端 ============
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000

# ============ 数据与索引目录 ============
DATA_DIR=./data
INDEX_DIR=./indexes
UPLOAD_MAX_SIZE_MB=2048

# ============ 日志 ============
LOG_LEVEL=INFO
