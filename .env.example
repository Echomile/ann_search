# ============ 应用安全 ============
SECRET_KEY=change-me-in-production-please
# JWT 过期时间（秒）
ACCESS_TOKEN_EXPIRE_SECONDS=86400

# ============ 数据库 ============
# 本地直连 (开发 / 本机调试)
DATABASE_URL=postgresql+asyncpg://ann:ann@localhost:5432/ann
# 容器内 (docker compose) 时使用 postgres 主机名
# DATABASE_URL=postgresql+asyncpg://ann:ann@postgres:5432/ann

# ============ 缓存 / 任务队列 ============
REDIS_URL=redis://localhost:6379/0

# ============ 大模型 (RAG) ============
# LLM_PROVIDER 可选：mock / anthropic / openai
#   mock      - 零依赖关键词规则，默认；无需任何 API Key 即可演示 RAG
#   anthropic - 调用 Claude (claude-opus-4-7)，需要 ANTHROPIC_API_KEY / LLM_API_KEY
#   openai    - OpenAI Chat Completions 兼容协议，可对接 OpenAI / Gemini / 兼容网关
LLM_PROVIDER=mock
LLM_MODEL=claude-opus-4-7
LLM_BASE_URL=                      # openai 兼容端点 base_url；留空走 OpenAI 官方
LLM_API_KEY=                       # 通用 API Key（openai/anthropic 共用，anthropic 缺 ANTHROPIC_API_KEY 时退回此值）
ANTHROPIC_API_KEY=                 # Anthropic 专用 Key，优先级高于 LLM_API_KEY
# 用 Gemini 时的示例配置：
#   LLM_PROVIDER=openai
#   LLM_MODEL=gemini-2.5-flash
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   LLM_API_KEY=<你的 Google AI Studio API Key>

# ============ 跨域 / 前端 ============
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000

# ============ 数据与索引目录 ============
DATA_DIR=./data
INDEX_DIR=./indexes
UPLOAD_MAX_SIZE_MB=2048

# ============ 日志 ============
LOG_LEVEL=INFO
